{
    "version": "0.2.0",
    "configurations": [

        // ── PowerShell ────────────────────────────────────────────
        {
            "name": "PowerShell: Launch Current File",
            "type": "PowerShell",
            "request": "launch",
            "script": "${file}",
            "args": []
        },

        // Edit VmName / VmPass / ScriptRelPath before using.
        // Set breakpoints in provision-script.ps1 or common.ps1, then press F5.
        {
            "name": "PowerShell: provision-script (debug)",
            "type": "PowerShell",
            "request": "launch",
            "script": "${workspaceFolder}/host/provision-script.ps1",
            "args": [
                "-VmName",        "FedoraBox",
                "-VmUser",        "root",
                "-VmPass",        "secret",
                "-LoginUser",     "fedora",
                "-ScriptRelPath", "tools/languages/java.sh",
                "-NonInteractive"
            ]
        },

        // ── Electron main process ─────────────────────────────────
        // Debugs the Node.js code in app/electron/ (main.js, ipc-handlers.js, etc.)
        // You can set breakpoints in those files and they will be hit.
        //
        // Before launching this, start the Vite dev server separately:
        //   cd app && npm run dev
        // Then launch this config — Electron will connect to Vite on port 5173.
        {
            "name": "Electron: Main Process",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/app/node_modules/.bin/electron",
            "runtimeArgs": ["--remote-debugging-port=9223", "."],
            "cwd": "${workspaceFolder}/app",
            "env": { "NODE_ENV": "development" },
            "sourceMaps": true,
            "resolveSourceMapLocations": ["${workspaceFolder}/app/electron/**"]
        },

        // ── Electron renderer (React) ─────────────────────────────
        // Debugs the React code in app/src/ (components, pages, etc.)
        // You can set breakpoints in .tsx files and they will be hit.
        //
        // This config attaches to the Chromium DevTools port opened by
        // the "Electron: Main Process" config above (port 9223).
        // Launch "Electron: Main Process" first, then attach this one.
        {
            "name": "Electron: Renderer (React)",
            "type": "chrome",
            "request": "attach",
            "port": 9223,
            "webRoot": "${workspaceFolder}/app/src",
            "timeout": 30000
        }
    ],

    // ── Compound: debug both at once ──────────────────────────────
    // Starts both configs together so you can debug the main process
    // and the React renderer at the same time.
    //
    // Before using this, start Vite separately: cd app && npx vite
    "compounds": [
        {
            "name": "Electron: Full Debug",
            "configurations": ["Electron: Main Process", "Electron: Renderer (React)"]
        }
    ]
}

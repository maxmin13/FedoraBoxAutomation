# Node / Electron
app/node_modules/
app/dist/
app/out/
app/.vite/

# Credentials — never commit these
.credentials/
.credentials.json

# Environment variable files — may contain secrets
.env
.env.local

# Log files
*.log

# Windows OS files
Thumbs.db
desktop.ini

# macOS OS files
.DS_Store

# Claude Code local settings (machine-specific, contains path permissions)
.claude/settings.local.json
